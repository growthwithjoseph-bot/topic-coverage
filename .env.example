# Topic Coverage — environment overrides.
# Copy to `.env` and edit. Every value here has a sensible default in
# backend/config.py, so the repo runs with NO keys and NO .env at all.

# --- Storage ---
# TC_DB_PATH=data/topic_coverage.db

# --- Crawl politeness / caps (SPEC §6.1–6.2) ---
# TC_MAX_PAGES_PER_DOMAIN=300
# TC_PER_HOST_CONCURRENCY=4
# TC_REQUEST_TIMEOUT=20
# TC_USER_AGENT=TopicCoverageBot/0.1 (+https://example.com/bot)
# TC_RESPECT_ROBOTS=true
# Pages to exclude from crawl + comparison (careers/hiring + legal/terms by
# default). Comma-separated path stems; replaces the built-in list.
# TC_EXCLUDE_URL_PATTERNS=careers,jobs,hiring,terms,privacy,legal,cookies

# --- Chunking / embeddings (SPEC §6.4) ---
# TC_CHUNK_MIN_TOKENS=200
# TC_CHUNK_MAX_TOKENS=500
# TC_CHUNK_OVERLAP_TOKENS=40
# TC_EMBEDDING_BACKEND=local          # local | openai
# TC_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Topic discovery (SPEC §6.4) ---
# TC_MIN_CLUSTER_SIZE=8
# TC_UMAP_N_NEIGHBORS=15
# TC_NUM_CATEGORIES_MIN=8
# TC_NUM_CATEGORIES_MAX=14

# --- Coverage scoring (SPEC §6.5–6.6) ---
# TC_SIM_THRESHOLD=0.35
# TC_PARITY_DELTA=0.10

# --- Optional LLM labels for topics/categories (term-based labels are the
#     free default; turn this on for nicer names) ---
# TC_LLM_LABELS=false
# TC_LLM_PROVIDER=anthropic            # anthropic | ollama
#
# Option A — local & free (no key). Install Ollama + pull a model first:
#   brew install ollama && ollama pull qwen2.5:3b
# TC_LLM_PROVIDER=ollama
# TC_LLM_MODEL=qwen2.5:3b              # or llama3.2:3b, gemma2:2b, deepseek-r1:1.5b
# TC_OLLAMA_HOST=http://localhost:11434
#
# Option B — Anthropic (needs credits + `pip install -e ".[llm]"`)
# TC_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# TC_LLM_MODEL=claude-opus-4-8         # or claude-haiku-4-5 for cheaper labelling
#
# OPENAI_API_KEY=
